# ─────────────────────────────────────────────────────────────────────────────
# Tarjuman — local environment template. Copy to `.env.local` and fill in.
#
# These are the SERVER-SIDE vars the Next.js app reads (dev: `.env.local`;
# prod: Vercel project env). Convex-side secrets (auth, email) are set
# SEPARATELY with `npx convex env set …` — listed at the bottom.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────

# Deepgram — realtime speech-to-text (the live transcript). In prod the key
# needs keys:write scope so the API route can mint short-lived session tokens.
DEEPGRAM_API_KEY=

# Anthropic — Claude (Haiku/Sonnet) translation + summaries. The product's core.
ANTHROPIC_API_KEY=

# OpenAI — Whisper second-opinion (off-language detection + accuracy reconcile)
# AND text-to-speech read-aloud. If unset OR out of quota, the app degrades
# gracefully: Deepgram-only transcription + the browser's Web Speech voice.
OPENAI_API_KEY=

# Convex backend URL (from `npx convex dev`). Public — safe in the client bundle.
NEXT_PUBLIC_CONVEX_URL=

# ── Optional ─────────────────────────────────────────────────────────────────

# Sunnah.com — hadith citation verification. WITHOUT this, hadith citations are
# marked "— unverified" (fail-safe) instead of pulling the authentic text +
# reference. Request a free key at sunnah.com. (Quran verification via
# quran.com / Muhsin Khan needs no key and always runs.)
SUNNAH_API_KEY=

# Deepgram project id — skips one discovery round-trip per session when set.
DEEPGRAM_PROJECT_ID=

# App URL for absolute links / OpenGraph. Falls back sensibly if unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry browser error tracking (client DSN).
NEXT_PUBLIC_SENTRY_DSN=

# Google Search Console domain-verification token.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─────────────────────────────────────────────────────────────────────────────
# Convex-side secrets — NOT read here. Set with: npx convex env set KEY value
#   AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET      Google OAuth
#   JWT_PRIVATE_KEY / JWKS                   Convex Auth token signing
#   RESEND_API_KEY / RESEND_FROM             transactional email
#   LOOPS_API_KEY / LOOPS_PASSWORD_RESET_ID  password-reset email
#   SITE_URL                                 app URL used in email links
# ─────────────────────────────────────────────────────────────────────────────
